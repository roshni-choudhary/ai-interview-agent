# Environment
SECRET_KEY=your-super-secret-key-change-in-production-abc123xyz
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite+aiosqlite:///./interview_agent.db

# LLM Provider: mock, openai, gemini
LLM_PROVIDER=mock

# OpenAI (optional)
OPENAI_API_KEY=

# Gemini (optional)
GEMINI_API_KEY=

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
